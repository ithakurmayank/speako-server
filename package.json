{
  "name": "speako-server",
  "version": "1.0.0",
  "main": "app.js",
  "type": "module",
  "description": "Backend server for Speako chat application",
  "author": "Mayank Thakur",
  "engines": {
    "node": ">=18"
  },
  "imports": {
    "#controllers/*": "./controllers/*",
    "#models/*": "./models/*",
    "#routes/*": "./routes/*",
    "#utils/*": "./utils/*",
    "#services/*": "./services/*",
    "#constants/*": "./constants/*",
    "#validators/*": "./validators/*",
    "#middlewares/*": "./middlewares/*"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon app.js",
    "start": "node app.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.0.2",
    "multer": "^2.0.2",
    "resend": "^6.10.0",
    "socket.io": "^4.8.3",
    "ua-parser-js": "^2.0.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.1.0",
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.11"
  },
  "_moduleAliases": {
    "@controllers": "controllers",
    "@models": "models",
    "@routes": "routes",
    "@utils": "utils",
    "@services": "services"
  }
}
